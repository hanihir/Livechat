{
  "name": "livechatr",
  "version": "1.0.7",
  "description": "Envoie une image en plein écran à tous tes amis connectés",
  "main": "src/main.js",
  "author": "Hani",
  "scripts": {
    "start": "electron .",
    "server": "node server/index.js",
    "dist": "electron-builder --win",
    "publish": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.livechatr.app",
    "productName": "LiveChatr",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LiveChatr"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hanihir",
        "repo": "Livechat",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
